usage: userApplications

dn: cn=person,cn=schema
objectClass: top
objectClass: ldapSubentry
objectClass: objectClassDescription
cn: person
description: Person object class
sup: top
must: cn
must: sn
may: mail
may: telephoneNumber

dn: cn=inetOrgPerson,cn=schema
objectClass: top
objectClass: ldapSubentry
objectClass: objectClassDescription
cn: inetOrgPerson
description: Internet Organization Person
sup: person
must: cn
may: departmentNumber

dn: cn=groupOfNames,cn=schema
objectClass: top
objectClass: ldapSubentry
objectClass: objectClassDescription
cn: groupOfNames
description: Group of names
