singleValue: FALSE
usage: userApplications

dn: cn=sn,cn=schema
objectClass: top
objectClass: ldapSubentry
objectClass: attributeTypeDescription
cn: sn
description: Surname
syntax: 1.3.6.1.4.1.1466.115.121.1.15
singleValue: FALSE
usage: userApplications

dn: cn=mail,cn=schema
objectClass: top
objectClass: ldapSubentry
objectClass: attributeTypeDescription
cn: mail
description: Email Address
syntax: 1.3.6.1.4.1.1466.115.121.1.26
singleValue: FALSE
usage: userApplications

dn: cn=member,cn=schema
objectClass: top
objectClass: ldapSubentry
objectClass: attributeTypeDescription
cn: member
description: Group member
syntax: 1.3.6.1.4.1.1466.115.121.1.12
