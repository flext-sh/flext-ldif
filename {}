        ] = {
            c.Ldif.CONVERSION_BOOLEAN_CONVERSIONS: boolean_conversions_dict,
            c.Ldif.CONVERSION_ATTRIBUTE_NAME_CONVERSIONS: attr_name_conversions,
        }
        converted_attrs_data_str: str = m.Ldif.DynamicMetadata.from_dict(
