        return super()._supports_feature(_feature_id)

    @override
    def _write_acl(self, acl_data: m.Ldif.Acl) -> r[str]:
        """Write ACL to RFC-compliant string format (internal)."""
        if acl_data.raw_acl and acl_data.raw_acl.strip():
