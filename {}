            raw_acl=acl_line,
            server_type=server_type_value,
            metadata=m.Ldif.QuirkMetadata(
                quirk_type=server_type_value,
                extensions=extensions_meta,
            ),
        )
        return r[m.Ldif.Acl].ok(acl_model)

    def _preserve_unsupported_feature(
        self,
