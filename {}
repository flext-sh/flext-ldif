        ).model_dump_json()
        generic_metadata[mk.CONVERTED_ATTRIBUTES] = converted_attrs_data_str
        generic_metadata[c.Ldif.ENTRY_TARGET_DN_CASE] = cleaned_dn
        generic_metadata[c.Ldif.ENTRY_ORIGINAL_FORMAT] = (
